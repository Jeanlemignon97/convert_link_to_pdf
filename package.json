{
  "name": "convert-content-link-to-pdf",
  "version": "1.0.0",
  "private": true,
  "description": "Convert web page content into a clean PDF.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "convert": "tsx src/index.ts",
    "web": "tsx src/web/server.ts",
    "start": "node dist/web/server.js",
    "test": "node --test --import tsx src/*.test.ts src/**/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "archiver": "^8.0.0",
    "express": "^5.2.1",
    "jsdom": "^26.1.0",
    "pdfkit": "^0.17.1"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.10.2",
    "@types/pdfkit": "^0.17.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
