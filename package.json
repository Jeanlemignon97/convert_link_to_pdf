{
  "name": "convert-link-to-pdf",
  "version": "1.0.0",
  "private": true,
  "description": "Convert a web page's main text content into a clean PDF.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "convert": "tsx src/index.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "jsdom": "^26.1.0",
    "pdfkit": "^0.17.1"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.10.2",
    "@types/pdfkit": "^0.17.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
